---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  summary?: string;
  date?: Date;
  tags?: string[];
  kind: 'project' | 'writing';
  status?: string;
  links?: { code?: string; paper?: string; demo?: string };
}
const { title, summary, date, tags = [], kind, status, links = {} } = Astro.props;
const kindLabel = kind === 'project' ? 'Project' : 'Essay';
const dateStr = date?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const linkEntries = Object.entries(links).filter(([, v]) => v);
const backHref = kind === 'project' ? '/projects' : '/writing';
---

<BaseLayout title={title} description={summary}>
  <article class="wrap prose-wrap">
    <a class="back mono" href={backHref}>← {kind === 'project' ? 'Projects' : 'Writing'}</a>

    <header class="prose-head">
      <div class="prose-head__meta">
        <span class="eyebrow">{kindLabel}</span>
        {dateStr && <span class="mono">{dateStr}</span>}
        {status && <span class="mono">{status}</span>}
      </div>
      <h1 class="prose-title">{title}</h1>
      {summary && <p class="prose-lede">{summary}</p>}
      {
        tags.length > 0 && (
          <ul class="tags prose-tags">
            {tags.map((t) => (
              <li class="tag">{t}</li>
            ))}
          </ul>
        )
      }
      {
        linkEntries.length > 0 && (
          <div class="prose-links">
            {linkEntries.map(([k, v]) => (
              <a class="link" href={v as string}>
                {k} ↗
              </a>
            ))}
          </div>
        )
      }
    </header>

    <hr class="rule" />

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .prose-wrap { max-width: 44rem; padding-top: 2.5rem; }
  .back { display: inline-block; margin-bottom: 2rem; color: var(--muted); }
  .back:hover { color: var(--accent-ink); }

  .prose-head__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
    margin-bottom: 0.9rem;
  }
  .prose-title {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.08;
    margin-bottom: 0.9rem;
  }
  .prose-lede {
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--muted);
    margin: 0 0 1.2rem;
  }
  .prose-tags { margin-bottom: 1.1rem; }
  .prose-links { display: flex; flex-wrap: wrap; gap: 1.2rem; font-family: var(--mono); font-size: 0.82rem; }
  .rule { margin-block: 2.2rem; }

  /* long-form reading styles */
  .prose { font-size: 1.12rem; line-height: 1.72; }
  .prose :global(h2) {
    font-size: 1.6rem;
    margin: 2.6rem 0 0.8rem;
    letter-spacing: -0.01em;
  }
  .prose :global(h3) { font-size: 1.28rem; margin: 2rem 0 0.6rem; }
  .prose :global(p) { margin: 0 0 1.25rem; }
  .prose :global(a) {
    color: var(--accent-ink);
    text-decoration: underline;
    text-decoration-color: var(--accent-weak);
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) { text-decoration-color: var(--accent); }
  .prose :global(ul),
  .prose :global(ol) { margin: 0 0 1.25rem; padding-left: 1.3rem; }
  .prose :global(li) { margin-bottom: 0.4rem; }
  .prose :global(blockquote) {
    margin: 1.5rem 0;
    padding-left: 1.1rem;
    border-left: 2px solid var(--accent);
    color: var(--muted);
    font-style: italic;
  }
  .prose :global(code) {
    font-family: var(--mono);
    font-size: 0.86em;
    background: var(--line-soft);
    padding: 0.12em 0.38em;
    border-radius: 4px;
  }
  .prose :global(pre) {
    background: var(--bg-raised);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
    font-size: 0.88rem;
    line-height: 1.55;
  }
  .prose :global(pre code) { background: none; padding: 0; }
  .prose :global(img) { max-width: 100%; height: auto; border-radius: 8px; }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 2.4rem 0; }
</style>
