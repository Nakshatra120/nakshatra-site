---
import BaseLayout from '../layouts/BaseLayout.astro';
import { RESEARCH } from '../data/research';
import { newTabIfExternal } from '../utils';
---

<BaseLayout title="Research" description="Formal research work.">
  <section class="wrap page-head">
    <p class="eyebrow">Research</p>
    <h1 class="page-title">Formal research</h1>
    <p class="page-intro">
      Peer-reviewable work — the rigorous core. For self-directed builds and
      experiments, see <a class="link" href="/projects">projects</a>.
    </p>
  </section>

  <section class="wrap">
    <ol class="research">
      {
        RESEARCH.map((r) => (
          <li class="entry">
            <div class="entry__meta">
              <span class="mono entry__period">{r.period}</span>
              {r.status && <span class="mono entry__status">{r.status}</span>}
            </div>
            <h2 class="entry__title">{r.title}</h2>
            <p class="entry__venue mono">
              {r.venue} · {r.role}
            </p>
            <p class="entry__summary">{r.summary}</p>
            {r.tags.length > 0 && (
              <ul class="tags entry__tags">
                {r.tags.map((t) => (
                  <li class="tag">{t}</li>
                ))}
              </ul>
            )}
            {r.links && r.links.length > 0 && (
              <div class="entry__links">
                {r.links.map((l) => (
                  <a class="link" href={l.href} {...newTabIfExternal(l.href)}>
                    {l.label} ↗
                  </a>
                ))}
              </div>
            )}
          </li>
        ))
      }
    </ol>
  </section>
</BaseLayout>

<style>
  .page-head { padding-block: clamp(2.5rem, 7vw, 4.5rem) 1.5rem; }
  .page-title { font-size: clamp(2.4rem, 6vw, 3.6rem); letter-spacing: -0.02em; margin: 0.4rem 0 0.8rem; }
  .page-intro { font-size: 1.2rem; color: var(--muted); max-width: 48ch; margin: 0; }

  .research { list-style: none; margin: 0; padding: 0; }
  .entry { padding-block: 2rem; border-top: 1px solid var(--line); }
  .entry__meta { display: flex; gap: 0.9rem; align-items: center; margin-bottom: 0.5rem; }
  .entry__period { color: var(--faint); }
  .entry__status {
    color: var(--accent-ink);
    background: var(--accent-weak);
    border-radius: 999px;
    padding: 0.05rem 0.55rem;
    font-size: 0.66rem;
  }
  .entry__title { font-size: clamp(1.5rem, 3.2vw, 2rem); max-width: var(--measure); }
  .entry__venue { margin: 0.4rem 0 0.9rem; color: var(--muted); text-transform: none; letter-spacing: 0.01em; font-size: 0.82rem; }
  .entry__summary { margin: 0 0 1rem; color: var(--ink); max-width: var(--measure); }
  .entry__links { display: flex; gap: 1.2rem; margin-top: 0.8rem; font-family: var(--mono); font-size: 0.82rem; }
</style>
